<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1625">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- ── Title block ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INDOOR POSITION\nDETECTION SYSTEM"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingMultiplier="1.15"
            android:paddingTop="10dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WiFi RSSI Positioning System"
            android:textColor="#557799"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="20dp"/>

        <!-- ── Section header ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ROOMS LIST WITH SIGNALS"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingBottom="10dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A3A55"
            android:layout_marginBottom="12dp"/>

        <!-- ── LAB 1 row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0D2137"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Computer icon box -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#2E7D32">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🖥"
                    android:textSize="20sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LAB 1"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="14dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/signalText1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="– dBm"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/commentText1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanning..."
                    android:textColor="#557799"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── LAB 2 row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0D2137"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#00838F">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🖥"
                    android:textSize="20sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LAB 2"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="14dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/signalText2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="– dBm"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/commentText2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanning..."
                    android:textColor="#557799"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── LAB 3 row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0D2137"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#4527A0">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🖥"
                    android:textSize="20sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LAB 3"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="14dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/signalText3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="– dBm"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/commentText3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanning..."
                    android:textColor="#557799"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── LAB 4 row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0D2137"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#283593">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🖥"
                    android:textSize="20sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LAB 4"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="14dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/signalText4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="– dBm"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/commentText4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanning..."
                    android:textColor="#557799"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Detected location card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D2137"
            android:padding="18dp"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="As per the signals, you're in"
                android:textColor="#7799AA"
                android:textSize="13sp"
                android:paddingBottom="6dp"/>

            <TextView
                android:id="@+id/detectedLabText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scanning..."
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#00E5FF"
                android:paddingBottom="12dp"/>

            <!-- Pulsing status bar -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="REAL-TIME TRACKING ACTIVE"
                android:textColor="#00E5FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:background="#0A2A3A"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- ── Bottom buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnRefresh"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="⟳  REFRESH"
                android:textColor="#0A1625"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#00E5FF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnViewMap"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="VIEW MAP  ▶"
                android:textColor="#0A1625"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#00FF9C"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>