<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1625">

    <!-- ── Top bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D2137"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            app:tint="#00E5FF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FLOOR MAP"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Live WiFi Position"
                android:textColor="#557799"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Spacer to balance the back button -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp"/>

    </LinearLayout>

    <!-- ── Detected lab banner ── -->
    <TextView
        android:id="@+id/mapDetectedLab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scanning..."
        android:textColor="#00FF9C"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#0D2A1F"
        android:padding="8dp"/>

    <!-- ── Map ── -->
    <com.example.indoorpositiondetectionsystem.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>